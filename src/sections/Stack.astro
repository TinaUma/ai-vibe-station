---
const roles = [
  {
    index: '01',
    title: 'Prompt Engineer / Vibe-coder',
    tags: ['LLM Integration', 'Chain-of-Thought', 'RAG', 'n8n', 'Automation'],
    description:
      'Создание логики AI-систем: проектирование промтов, интеграция LLM (GPT-4, Claude, Groq), автоматизация флоу через n8n и Make. Вайб-кодинг с Cursor — от идеи до работающего прототипа.',
    accent: true,
  },
  {
    index: '02',
    title: 'Product Designer',
    tags: ['Product Thinking', 'UX Research', 'Rapid Prototyping', 'Business Logic'],
    description:
      'Проектирование путей пользователя, декомпозиция задач бизнеса, построение логики продукта. 7+ лет опыта в архитектуре и дизайне сложных систем.',
    accent: false,
  },
  {
    index: '03',
    title: 'UI/UX & Systems',
    tags: ['Figma', 'Design Systems', 'Interaction Design', 'AI Visuals'],
    description:
      'Интерфейсы как часть системы. Figma, AI-генерация образов, иллюстрация. Эстетика, которая работает — не украшение, а коммуникация.',
    accent: false,
  },
];
---

<section id="stack" class="stack-section">
  <div class="container-site">

    <div class="section-header">
      <span class="section-label font-mono">01 / stack</span>
      <h2 class="section-title font-serif">Чем я занимаюсь</h2>
    </div>

    <div class="roles-list">
      {roles.map(role => (
        <div class:list={['role-card', { 'role-card--accent': role.accent }]}>
          <span class="role-index font-mono">{role.index}</span>
          <div class="role-body">
            <h3 class="role-title">{role.title}</h3>
            <p class="role-desc">{role.description}</p>
            <div class="role-tags">
              {role.tags.map(tag => (
                <span class="tag font-mono">{tag}</span>
              ))}
            </div>
          </div>
          {role.accent && (
            <span class="role-badge font-mono">primary</span>
          )}
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .stack-section {
    padding: 6rem 0;
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border);
  }

  .section-header {
    margin-bottom: 3rem;
  }

  .section-label {
    display: block;
    font-size: 0.7rem;
    color: var(--accent);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--text-primary);
  }

  .roles-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-radius: 0.5rem;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }

  .role-card {
    display: grid;
    grid-template-columns: 3.5rem 1fr auto;
    align-items: start;
    gap: 2rem;
    padding: 2rem 2rem;
    background: var(--bg-card);
    border-bottom: 1px solid var(--border);
    transition: background 0.2s;
    position: relative;
  }

  .role-card:last-child {
    border-bottom: none;
  }

  .role-card:hover {
    background: var(--bg-secondary);
  }

  .role-card--accent {
    border-left: 3px solid var(--accent);
  }

  .role-card--accent:hover {
    background: var(--accent-bg);
  }

  .role-index {
    font-size: 0.7rem;
    color: var(--text-muted);
    padding-top: 0.15rem;
    letter-spacing: 0.08em;
  }

  .role-body {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .role-title {
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  .role-desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.75;
    max-width: 600px;
  }

  .role-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.2rem;
  }

  .tag {
    font-size: 0.65rem;
    padding: 0.2rem 0.6rem;
    border-radius: 99px;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    color: var(--text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .role-card--accent .tag {
    background: var(--accent-bg);
    border-color: var(--border-accent);
    color: var(--accent);
  }

  .role-badge {
    font-size: 0.62rem;
    color: var(--accent);
    background: var(--accent-bg);
    border: 1px solid var(--border-accent);
    padding: 0.2rem 0.55rem;
    border-radius: 99px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    align-self: flex-start;
    white-space: nowrap;
  }

  @media (max-width: 640px) {
    .role-card {
      grid-template-columns: 2.5rem 1fr;
      gap: 1rem;
      padding: 1.5rem;
    }

    .role-badge {
      position: absolute;
      top: 1.5rem;
      right: 1.5rem;
    }
  }
</style>
