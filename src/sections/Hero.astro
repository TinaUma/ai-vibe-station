---
---

<section id="hero" class="hero">
  <div class="container-site hero-inner">

    <!-- LEFT -->
    <div class="hero-left">
      <div class="hero-badge font-mono">
        <span class="badge-dot"></span>
        available for collaboration
      </div>

      <h1 class="hero-name font-head">
        Tina<br /><span class="name-accent">Uma</span>
      </h1>

      <p class="hero-role font-head">
        AI-Driven Product Engineer
      </p>

      <p class="hero-desc">
        Проектирую полезные системы. Выстраиваю логику,
        соединяю AI-инструменты и довожу идеи
        до работающего продукта.
      </p>

      <div class="hero-cta">
        <a href="#projects" class="btn-orange font-head">Смотреть проекты</a>
        <a href="#contact" class="btn-ghost font-head">Написать →</a>
      </div>

      <!-- Vitruvius row -->
      <div class="vitruvius-row">
        <div class="vit-item">
          <span class="vit-latin font-mono">Utilitas</span>
          <span class="vit-ru">Польза</span>
        </div>
        <div class="vit-sep"></div>
        <div class="vit-item">
          <span class="vit-latin font-mono">Firmitas</span>
          <span class="vit-ru">Прочность</span>
        </div>
        <div class="vit-sep"></div>
        <div class="vit-item">
          <span class="vit-latin font-mono">Venustas</span>
          <span class="vit-ru">Красота</span>
        </div>
      </div>
    </div>

    <!-- RIGHT: Photo -->
    <div class="hero-right">
      <div class="photo-wrap">
        <img src="/tina.jpg" alt="Tina Umasheva" class="hero-photo" />
        <div class="photo-tag font-mono">
          <span>Prompt Engineer</span>
          <span class="tag-sep">/</span>
          <span>Vibe-coder</span>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .hero {
    padding: 7rem 0 4rem;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 4rem;
    align-items: center;
  }

  /* Badge */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    animation: fadeUp 0.5s ease both;
  }

  .badge-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--orange);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* Name */
  .hero-name {
    font-size: clamp(3.5rem, 9vw, 6rem);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--text);
    margin-bottom: 1rem;
    animation: fadeUp 0.5s 0.05s ease both;
  }

  .name-accent { color: var(--orange); }

  /* Role */
  .hero-role {
    font-size: clamp(1rem, 2vw, 1.2rem);
    font-weight: 500;
    color: var(--text-secondary);
    margin-bottom: 1.25rem;
    letter-spacing: -0.01em;
    animation: fadeUp 0.5s 0.1s ease both;
  }

  /* Desc */
  .hero-desc {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.75;
    max-width: 440px;
    margin-bottom: 2rem;
    animation: fadeUp 0.5s 0.15s ease both;
  }

  /* CTA */
  .hero-cta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
    animation: fadeUp 0.5s 0.2s ease both;
  }

  .btn-orange {
    padding: 0.7rem 1.6rem;
    background: var(--orange);
    color: #fff;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 4px;
    letter-spacing: 0.01em;
    transition: background 0.2s, transform 0.15s;
  }
  .btn-orange:hover { background: var(--orange-dark); transform: translateY(-1px); }
  .btn-orange:active { transform: scale(0.98); }

  .btn-ghost {
    padding: 0.7rem 1.4rem;
    border: 1.5px solid var(--border);
    color: var(--text-secondary);
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
    border-radius: 4px;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-ghost:hover { border-color: var(--orange); color: var(--orange); }

  /* Vitruvius */
  .vitruvius-row {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.25rem 1.5rem;
    background: var(--bg-alt);
    border-radius: 6px;
    border-left: 3px solid var(--orange);
    animation: fadeUp 0.5s 0.25s ease both;
  }

  .vit-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .vit-latin {
    font-size: 0.62rem;
    color: var(--orange);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .vit-ru {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text);
  }

  .vit-sep {
    width: 1px;
    height: 32px;
    background: var(--border);
    flex-shrink: 0;
  }

  /* Photo */
  .hero-right {
    animation: fadeUp 0.6s 0.08s ease both;
  }

  .photo-wrap {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .hero-photo {
    width: 100%;
    max-width: 300px;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    object-position: center top;
    border-radius: 8px;
    display: block;
    box-shadow: var(--shadow-lg);
  }

  .photo-tag {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.65rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .tag-sep { color: var(--orange); }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 860px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .hero-right {
      order: -1;
      display: flex;
      justify-content: center;
    }
    .hero-photo { max-width: 220px; aspect-ratio: 1/1; }
  }

  @media (max-width: 480px) {
    .vitruvius-row { flex-direction: column; align-items: flex-start; gap: 0.75rem; }
    .vit-sep { width: 24px; height: 1px; }
  }
</style>
