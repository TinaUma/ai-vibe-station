---
---

<section id="hero" class="hero-section">
  <div class="container-site">

    <!-- Noise / grid background layer -->
    <div class="hero-grid-bg" aria-hidden="true"></div>

    <!-- Top label -->
    <div class="hero-label">
      <span class="font-mono" style="color: var(--accent-green); font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase;">
        ◈ Available for collaboration
      </span>
    </div>

    <!-- Vitruvius quote → manifest transition -->
    <div class="hero-quote">
      <p class="vitruvius-text font-mono">
        <span style="color: var(--text-muted)">// Vitruvius, De Architectura, 25 BC</span><br />
        <span style="color: var(--text-secondary)">"Firmitas. Utilitas. Venustas."</span>
      </p>
    </div>

    <!-- Main title block -->
    <div class="hero-title-block">
      <h1 class="hero-name">Tina Uma</h1>
      <p class="hero-role font-mono">
        <span style="color: var(--accent-green)">AI-Driven</span>
        <span style="color: var(--text-secondary)"> Product Engineer</span>
      </p>
      <p class="hero-manifesto">
        Я проектирую полезные системы.<br />
        Выстраиваю логику, соединяю AI-инструменты<br />
        и довожу идеи до работающего продукта.
      </p>
      <div class="hero-cta">
        <a href="#stack" class="btn-primary font-mono">
          → explore stack
        </a>
        <a href="#contact" class="btn-secondary font-mono">
          → get in touch
        </a>
      </div>
    </div>

    <!-- Vitruvius three pillars -->
    <div class="vitruvius-pillars">
      <div class="pillar">
        <span class="pillar-latin font-mono">Utilitas</span>
        <span class="pillar-divider">—</span>
        <span class="pillar-title">Польза</span>
        <p class="pillar-desc">Продуктовый дизайн и решение задач бизнеса</p>
      </div>
      <div class="pillar-separator" aria-hidden="true"></div>
      <div class="pillar">
        <span class="pillar-latin font-mono">Firmitas</span>
        <span class="pillar-divider">—</span>
        <span class="pillar-title">Прочность</span>
        <p class="pillar-desc">Надёжная архитектура систем и чистый код</p>
      </div>
      <div class="pillar-separator" aria-hidden="true"></div>
      <div class="pillar">
        <span class="pillar-latin font-mono">Venustas</span>
        <span class="pillar-divider">—</span>
        <span class="pillar-title">Красота</span>
        <p class="pillar-desc">Эстетика взаимодействия и UX</p>
      </div>
    </div>

  </div>
</section>

<style>
  .hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 6rem 0 4rem;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }

  .hero-section .container-site {
    position: relative;
    z-index: 1;
    width: 100%;
  }

  /* Subtle grid background */
  .hero-grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 60px 60px;
    opacity: 0.3;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 40%, transparent 100%);
  }

  /* Top label */
  .hero-label {
    margin-bottom: 2.5rem;
    animation: fadeInUp 0.6s ease both;
  }

  /* Vitruvius quote */
  .hero-quote {
    margin-bottom: 2rem;
    animation: fadeInUp 0.6s 0.1s ease both;
  }

  .vitruvius-text {
    font-size: 0.85rem;
    line-height: 1.8;
    opacity: 0.7;
  }

  /* Title block */
  .hero-title-block {
    margin-bottom: 4rem;
    animation: fadeInUp 0.7s 0.2s ease both;
  }

  .hero-name {
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .hero-role {
    font-size: clamp(1rem, 2.5vw, 1.4rem);
    margin-bottom: 1.5rem;
    letter-spacing: 0.02em;
  }

  .hero-manifesto {
    font-size: clamp(0.95rem, 1.8vw, 1.1rem);
    color: var(--text-secondary);
    line-height: 1.9;
    max-width: 520px;
    margin-bottom: 2rem;
  }

  /* CTA buttons */
  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-block;
    padding: 0.65rem 1.4rem;
    background: var(--accent-green);
    color: #080b0f;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: opacity 0.2s, transform 0.2s;
  }

  .btn-primary:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  .btn-secondary {
    display: inline-block;
    padding: 0.65rem 1.4rem;
    border: 1px solid var(--border-accent);
    color: var(--text-secondary);
    font-size: 0.85rem;
    font-weight: 400;
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: border-color 0.2s, color 0.2s, transform 0.2s;
  }

  .btn-secondary:hover {
    border-color: var(--accent-green);
    color: var(--accent-green);
    transform: translateY(-1px);
  }

  /* Vitruvius pillars */
  .vitruvius-pillars {
    display: flex;
    align-items: flex-start;
    gap: 0;
    border: 1px solid var(--border);
    background: var(--bg-card);
    animation: fadeInUp 0.7s 0.35s ease both;
  }

  .pillar {
    flex: 1;
    padding: 1.75rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    transition: background 0.2s;
  }

  .pillar:hover {
    background: rgba(0, 212, 161, 0.04);
  }

  .pillar-separator {
    width: 1px;
    align-self: stretch;
    background: var(--border);
  }

  .pillar-latin {
    font-size: 0.75rem;
    color: var(--accent-green);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .pillar-divider {
    display: none;
  }

  .pillar-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .pillar-desc {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-top: 0.25rem;
  }

  /* Animations */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Mobile */
  @media (max-width: 768px) {
    .hero-section {
      padding: 5rem 0 3rem;
    }

    .vitruvius-pillars {
      flex-direction: column;
    }

    .pillar-separator {
      width: 100%;
      height: 1px;
    }

    .pillar {
      padding: 1.25rem 1.5rem;
    }
  }
</style>
