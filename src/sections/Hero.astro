---
---

<section id="hero" class="hero-section">
  <div class="container-site hero-inner">

    <!-- Left: content -->
    <div class="hero-content">

      <div class="hero-label font-mono">
        ◈ available for collaboration
      </div>

      <div class="hero-quote font-mono">
        <span class="quote-comment">// Vitruvius, De Architectura, 25 BC</span><br />
        <span class="quote-text">"Firmitas. Utilitas. Venustas."</span>
      </div>

      <h1 class="hero-name font-serif">Tina Uma</h1>

      <p class="hero-role">
        <span class="role-accent">AI-Driven</span> Product Engineer
      </p>

      <p class="hero-manifesto">
        Я проектирую полезные системы.<br />
        Выстраиваю логику, соединяю AI-инструменты<br />
        и довожу идеи до работающего продукта.
      </p>

      <div class="hero-cta">
        <a href="#stack" class="btn-primary font-mono">
          explore stack →
        </a>
        <a href="#contact" class="btn-secondary font-mono">
          get in touch
        </a>
      </div>

      <!-- Vitruvius pillars -->
      <div class="vitruvius-pillars">
        <div class="pillar">
          <span class="pillar-latin font-mono">Utilitas</span>
          <span class="pillar-title">Польза</span>
          <p class="pillar-desc">Продуктовый дизайн и решение задач бизнеса</p>
        </div>
        <div class="pillar-sep" aria-hidden="true"></div>
        <div class="pillar">
          <span class="pillar-latin font-mono">Firmitas</span>
          <span class="pillar-title">Прочность</span>
          <p class="pillar-desc">Надёжная архитектура систем и чистый код</p>
        </div>
        <div class="pillar-sep" aria-hidden="true"></div>
        <div class="pillar">
          <span class="pillar-latin font-mono">Venustas</span>
          <span class="pillar-title">Красота</span>
          <p class="pillar-desc">Эстетика взаимодействия и UX</p>
        </div>
      </div>

    </div>

    <!-- Right: photo -->
    <div class="hero-photo-wrap">
      <div class="hero-photo-frame">
        <img
          src="/tina.jpg"
          alt="Tina Umasheva"
          class="hero-photo"
          loading="eager"
        />
      </div>
      <div class="hero-photo-caption font-mono">
        <span>Moscow, Russia</span>
        <span class="caption-sep">·</span>
        <span>Prompt Engineer</span>
      </div>
    </div>

  </div>
</section>

<style>
  .hero-section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 7rem 0 5rem;
    border-bottom: 1px solid var(--border);
    background: var(--bg-primary);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 5rem;
    align-items: center;
    width: 100%;
  }

  /* Label */
  .hero-label {
    font-size: 0.7rem;
    color: var(--accent);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 2rem;
    animation: fadeInUp 0.5s ease both;
  }

  /* Quote */
  .hero-quote {
    margin-bottom: 1.75rem;
    animation: fadeInUp 0.5s 0.08s ease both;
  }

  .quote-comment {
    font-size: 0.78rem;
    color: var(--text-muted);
    font-family: 'DM Mono', monospace;
  }

  .quote-text {
    font-size: 0.85rem;
    color: var(--text-secondary);
    font-family: 'DM Mono', monospace;
  }

  /* Name */
  .hero-name {
    font-size: clamp(3rem, 7vw, 5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: var(--text-primary);
    margin-bottom: 0.6rem;
    animation: fadeInUp 0.6s 0.12s ease both;
  }

  .hero-role {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    font-weight: 400;
    letter-spacing: -0.01em;
    animation: fadeInUp 0.6s 0.16s ease both;
  }

  .role-accent {
    color: var(--accent);
    font-weight: 500;
  }

  .hero-manifesto {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.9;
    max-width: 460px;
    margin-bottom: 2rem;
    animation: fadeInUp 0.6s 0.2s ease both;
  }

  /* CTA */
  .hero-cta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 3rem;
    animation: fadeInUp 0.6s 0.24s ease both;
  }

  .btn-primary {
    display: inline-block;
    padding: 0.7rem 1.5rem;
    background: linear-gradient(145deg, var(--accent), var(--accent-dim));
    color: #ffffff;
    font-size: 0.78rem;
    font-weight: 500;
    text-decoration: none;
    letter-spacing: 0.06em;
    border-radius: 0.375rem;
    transition: opacity 0.2s, transform 0.15s;
    box-shadow: var(--shadow-sm);
  }

  .btn-primary:hover {
    opacity: 0.88;
    transform: translateY(-1px);
  }

  .btn-primary:active {
    transform: scale(0.98);
  }

  .btn-secondary {
    display: inline-block;
    padding: 0.7rem 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    color: var(--text-secondary);
    font-size: 0.78rem;
    font-weight: 400;
    text-decoration: none;
    letter-spacing: 0.06em;
    border-radius: 0.375rem;
    transition: border-color 0.2s, color 0.2s, transform 0.15s;
    box-shadow: var(--shadow-sm);
  }

  .btn-secondary:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-1px);
  }

  /* Pillars */
  .vitruvius-pillars {
    display: flex;
    align-items: stretch;
    background: var(--bg-card);
    border-radius: 0.5rem;
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    animation: fadeInUp 0.6s 0.3s ease both;
  }

  .pillar {
    flex: 1;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    transition: background 0.2s;
  }

  .pillar:hover {
    background: var(--accent-bg);
  }

  .pillar-sep {
    width: 1px;
    background: var(--border);
    align-self: stretch;
  }

  .pillar-latin {
    font-size: 0.65rem;
    color: var(--accent);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 0.1rem;
  }

  .pillar-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .pillar-desc {
    font-size: 0.78rem;
    color: var(--text-secondary);
    line-height: 1.55;
    margin-top: 0.25rem;
  }

  /* Photo */
  .hero-photo-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    animation: fadeInUp 0.7s 0.1s ease both;
  }

  .hero-photo-frame {
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: 0.5rem;
    box-shadow: var(--shadow-md);
  }

  .hero-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .hero-photo-caption {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.08em;
  }

  .caption-sep {
    opacity: 0.4;
  }

  /* Animation */
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Mobile */
  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .hero-photo-wrap {
      order: -1;
      max-width: 280px;
      margin: 0 auto;
    }
  }

  @media (max-width: 640px) {
    .vitruvius-pillars {
      flex-direction: column;
    }

    .pillar-sep {
      width: 100%;
      height: 1px;
    }

    .hero-photo-frame {
      aspect-ratio: 1 / 1;
    }
  }
</style>
