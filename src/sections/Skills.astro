---
const groups = [
  {
    code: '01',
    category: 'Промт-инжиниринг',
    items: ['Zero-shot / Few-shot / Chain-of-Thought', 'Системные и пользовательские промты', 'Тестирование на галлюцинации', 'Контекстное проектирование', 'Итеративная отладка'],
  },
  {
    code: '02',
    category: 'AI & Автоматизация',
    items: ['LLM: GPT-4, Claude, Groq', 'RAG + векторные БД (FAISS, Chroma)', 'n8n (флоу, webhooks)', 'Make, Voiceflow, 11Labs, HeyGen', 'Embeddings & семантический поиск'],
  },
  {
    code: '03',
    category: 'Разработка',
    items: ['Python (LangChain, Requests, JSON)', 'Cursor vibe-coding', 'Git, GitHub / GitLab', 'Astro, HTML/CSS', 'VS Code'],
  },
  {
    code: '04',
    category: 'Design & Visual',
    items: ['Figma, Design Systems', 'Adobe Photoshop, Procreate', 'AI-генерация (Midjourney)', 'UX Research & Prototyping', 'Архитектурная визуализация'],
  },
];
---

<section id="skills" class="skills-section">
  <div class="container-site">
    <div class="section-header">
      <span class="section-label">skills</span>
      <h2 class="section-title">Инструменты</h2>
    </div>
    <div class="skills-grid">
      {groups.map(g => (
        <div class="skill-card">
          <div class="skill-card-head">
            <span class="skill-code font-mono">{g.code}</span>
            <h3 class="skill-cat font-head">{g.category}</h3>
          </div>
          <ul class="skill-list">
            {g.items.map(item => (
              <li class="skill-item">
                <span class="item-dot" aria-hidden="true"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .skills-section {
    padding: 5rem 0;
    background: var(--bg-alt);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .section-header { margin-bottom: 2.5rem; }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .skill-card {
    background: var(--bg);
    border-radius: 8px;
    padding: 1.75rem;
    box-shadow: var(--shadow);
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .skill-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .skill-card-head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  .skill-code {
    font-size: 0.62rem;
    color: var(--orange);
    background: var(--orange-bg);
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    letter-spacing: 0.1em;
  }

  .skill-cat {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.01em;
  }

  .skill-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .skill-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.84rem;
    color: var(--text-secondary);
    line-height: 1.4;
  }

  .item-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--orange);
    flex-shrink: 0;
    opacity: 0.6;
  }

  @media (max-width: 620px) {
    .skills-grid { grid-template-columns: 1fr; }
  }
</style>
