---
const skillGroups = [
  {
    category: 'Промт-инжиниринг',
    code: 'prompt_engineering',
    items: [
      'Zero-shot / Few-shot / Chain-of-Thought',
      'Системные и пользовательские промты',
      'Тестирование на галлюцинации',
      'Контекстное проектирование',
      'Итеративная отладка',
    ],
  },
  {
    category: 'AI & Автоматизация',
    code: 'ai_automation',
    items: [
      'LLM: GPT-4, Claude, Groq',
      'RAG + векторные БД (FAISS, Chroma)',
      'n8n (вложенные флоу, webhooks)',
      'Make, Voiceflow, 11Labs, HeyGen',
      'Embeddings & семантический поиск',
    ],
  },
  {
    category: 'Разработка',
    code: 'development',
    items: [
      'Python (LangChain, Requests, JSON)',
      'Cursor vibe-coding',
      'Git, GitHub / GitLab',
      'Astro, HTML/CSS',
      'VS Code',
    ],
  },
  {
    category: 'Design & Visual',
    code: 'design',
    items: [
      'Figma, Design Systems',
      'Adobe Photoshop, Procreate',
      'AI-генерация образов (Midjourney)',
      'UX Research & Prototyping',
      'Архитектурная визуализация',
    ],
  },
];
---

<section id="skills" class="skills-section">
  <div class="container-site">

    <div class="section-header">
      <span class="section-label font-mono">02 / skills</span>
      <h2 class="section-title font-serif">Инструменты</h2>
    </div>

    <div class="skills-grid">
      {skillGroups.map(group => (
        <div class="skill-group">
          <div class="skill-group-header">
            <span class="skill-code font-mono">{group.code}</span>
            <h3 class="skill-category">{group.category}</h3>
          </div>
          <ul class="skill-list font-mono">
            {group.items.map(item => (
              <li class="skill-item">
                <span class="skill-bullet" aria-hidden="true">›</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .skills-section {
    padding: 6rem 0;
    background: var(--bg-primary);
    border-bottom: 1px solid var(--border);
  }

  .section-header {
    margin-bottom: 3rem;
  }

  .section-label {
    display: block;
    font-size: 0.7rem;
    color: var(--accent);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--text-primary);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .skill-group {
    background: var(--bg-card);
    border-radius: 0.5rem;
    padding: 1.75rem;
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.2s;
  }

  .skill-group:hover {
    box-shadow: var(--shadow-md);
  }

  .skill-group-header {
    margin-bottom: 1.25rem;
  }

  .skill-code {
    display: block;
    font-size: 0.62rem;
    color: var(--accent);
    letter-spacing: 0.14em;
    text-transform: lowercase;
    margin-bottom: 0.35rem;
    opacity: 0.75;
  }

  .skill-category {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .skill-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .skill-item {
    display: flex;
    align-items: baseline;
    gap: 0.55rem;
    font-size: 0.78rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .skill-bullet {
    color: var(--accent);
    flex-shrink: 0;
    font-size: 0.8rem;
  }

  @media (max-width: 640px) {
    .skills-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
