---
const projects = [
  {
    id: '01',
    title: 'Utility Bot',
    type: 'Telegram Bot',
    description: 'Телеграм-бот для учёта коммунальных платежей. Принимает показания счётчиков, рассчитывает стоимость воды и электричества по тарифам, сохраняет в Google Sheets.',
    tags: ['Python', 'Telegram API', 'Google Sheets'],
    link: 'https://github.com/TinaUma/utility-bot',
  },
  {
    id: '02',
    title: 'PitchMe AI Matcher',
    type: 'HR Automation',
    description: 'AI-инструмент для HR-скрининга: принимает PDF резюме и вакансию через webhook, оценивает соответствие кандидата через GPT-4o и возвращает match-score отчёт.',
    tags: ['React', 'n8n', 'GPT-4o', 'TypeScript'],
    link: 'https://github.com/TinaUma/pitchme-ai-matcher',
  },
  {
    id: '03',
    title: 'AI Media Factory',
    type: 'Autonomous Pipeline',
    description: 'Автономный конвейер новостных видео: ежедневно забирает новости AI-стартапов с Hacker News, генерирует сценарий, создаёт видео с аватаром и публикует в YouTube Shorts.',
    tags: ['n8n', 'GPT-4o', 'HeyGen', 'ElevenLabs'],
    link: 'https://github.com/TinaUma/ai-media-factory',
  },
  {
    id: '04',
    title: 'RAG + Supabase + Yandex',
    type: 'Knowledge Base',
    description: 'RAG-агент на n8n: забирает документы с Яндекс Диска, хранит как векторы в Supabase, отвечает на вопросы с краткосрочной и долгосрочной памятью.',
    tags: ['n8n', 'Supabase', 'RAG', 'OpenAI'],
    link: 'https://github.com/TinaUma/rag-n8n-supabase-YANDEXdisk',
  },
  {
    id: '05',
    title: 'AI-ассистент SMAIPL',
    type: 'Demo',
    description: 'Разработала и презентовала AI-ассистента в рамках стажировки. Проектирование промтов, логика диалога, демонстрация возможностей LLM.',
    tags: ['Prompt Engineering', 'LLM'],
    link: 'https://www.youtube.com/watch?v=tts6Ujd2lJo',
    isVideo: true,
  },
  {
    id: '06',
    title: 'Contact Enrichment Pipeline',
    type: 'Technical Case',
    description: 'Tiered Early-Exit архитектура для сбора контактов (email, телефон, соцсети) из открытых источников по 1M+ записей. Экономия 3–4× за счёт каскадной остановки на первом совпадении.',
    tags: ['Python', 'Celery', 'Redis', 'Gemini', 'AWS'],
    link: 'https://github.com/TinaUma/test2026',
  },
  {
    id: '07',
    title: 'VisionStyle',
    type: 'Vision AI',
    description: 'Загрузи фото — получи структурированный стиль-паспорт: палитра HEX, материалы, настроение, ключевые слова и вердикт. FastAPI + Next.js + Claude Vision. Задеплоено на HuggingFace.',
    tags: ['Python', 'FastAPI', 'Next.js', 'Claude Vision', 'TypeScript'],
    link: 'https://github.com/TinaUma/VisionStyle',
    liveUrl: 'https://tinaume-visionstyle.hf.space',
  },
];
---

<section id="projects" class="projects-section">
  <div class="container-site">
    <div class="section-header">
      <span class="section-label">projects</span>
      <h2 class="section-title section-title--light">Проекты</h2>
    </div>
    <div class="projects-grid">
      {projects.map(p => (
        <a href={p.liveUrl ?? p.link} target="_blank" rel="noopener noreferrer" class="project-card">
          <div class="card-top">
            <span class="card-id font-mono">{p.id}</span>
            <span class="card-type font-mono">{p.type}</span>
          </div>
          <h3 class="card-title font-head">{p.title}</h3>
          <p class="card-desc">{p.description}</p>
          <div class="card-bottom">
            <div class="card-tags">
              {p.tags.map(t => <span class="tag font-mono">{t}</span>)}
            </div>
            {p.liveUrl
              ? <span class="card-arrow card-arrow--live">Live Demo ↗</span>
              : <span class="card-arrow">{p.isVideo ? '▶ демо' : 'GitHub →'}</span>
            }
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .projects-section {
    padding: 5rem 0;
    background: var(--bg-dark2);
  }

  .section-header { margin-bottom: 2.5rem; }

  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 0.75rem;
  }
  .section-label::before {
    content: '';
    display: inline-block;
    width: 20px; height: 2px;
    background: var(--orange);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border-dark);
    border: 1px solid var(--border-dark);
    border-radius: 8px;
    overflow: hidden;
  }

  .project-card {
    background: var(--bg-dark);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    text-decoration: none;
    transition: background 0.2s;
    cursor: pointer;
  }

  .project-card:hover { background: rgba(255,85,0,0.07); }
  .project-card:hover .card-arrow { color: var(--orange); }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .card-id {
    font-size: 0.6rem;
    color: rgba(255,255,255,0.2);
    letter-spacing: 0.1em;
  }

  .card-type {
    font-size: 0.6rem;
    color: var(--orange);
    background: rgba(255,85,0,0.12);
    border: 1px solid rgba(255,85,0,0.25);
    padding: 0.1rem 0.4rem;
    border-radius: 99px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .card-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text-on-dark);
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .card-desc {
    font-size: 0.82rem;
    color: var(--text-on-dark-secondary);
    line-height: 1.7;
    flex: 1;
  }

  .card-bottom {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 0.5rem;
    margin-top: auto;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border-dark);
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .tag {
    font-size: 0.58rem;
    padding: 0.12rem 0.45rem;
    border-radius: 99px;
    border: 1px solid var(--border-dark);
    color: rgba(255,255,255,0.35);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .card-arrow {
    font-size: 0.72rem;
    color: rgba(255,255,255,0.3);
    flex-shrink: 0;
    font-family: 'IBM Plex Mono', monospace;
    transition: color 0.2s;
    white-space: nowrap;
  }

  .card-arrow--live {
    color: var(--orange);
    opacity: 0.7;
  }
  .project-card:hover .card-arrow--live { opacity: 1; }

  @media (max-width: 860px) {
    .projects-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .projects-grid { grid-template-columns: 1fr; }
  }
</style>
