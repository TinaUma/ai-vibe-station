---
const links = [
  {
    label: 'Email',
    value: 'tina.jumasheva@gmail.com',
    href: 'mailto:tina.jumasheva@gmail.com',
    code: 'mailto',
  },
  {
    label: 'Telegram',
    value: '@tina_uma',
    href: 'https://t.me/tina_uma',
    code: 'tg',
  },
  {
    label: 'GitHub',
    value: 'TinaUma',
    href: 'https://github.com/TinaUma',
    code: 'gh',
  },
  {
    label: 'Behance',
    value: 'tinayumasheva',
    href: 'https://www.behance.net/tinayumasheva',
    code: 'be',
  },
];
---

<section id="contact" class="contact-section">
  <div class="container-site">

    <div class="contact-grid">

      <div class="contact-left">
        <span class="section-label font-mono">// 04 — contact</span>
        <h2 class="contact-title">
          Готова к&nbsp;новым<br />проектам
        </h2>
        <p class="contact-sub">
          Открыта к сотрудничеству в AI-командах,<br />
          продуктовых лабораториях и стартапах.
        </p>
      </div>

      <div class="contact-right">
        {links.map(link => (
          <a href={link.href} target="_blank" rel="noopener noreferrer" class="contact-link">
            <span class="contact-link-meta">
              <span class="contact-code font-mono">{link.code}</span>
              <span class="contact-label">{link.label}</span>
            </span>
            <span class="contact-value font-mono">{link.value}</span>
            <span class="contact-arrow">→</span>
          </a>
        ))}
      </div>

    </div>

    <div class="footer-line">
      <span class="font-mono" style="font-size: 0.7rem; color: var(--text-muted); letter-spacing: 0.1em;">
        © 2025 Tina Umasheva — built with Astro + Claude Code
      </span>
    </div>

  </div>
</section>

<style>
  .contact-section {
    padding: 6rem 0 4rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    margin-bottom: 4rem;
    align-items: start;
  }

  .section-label {
    display: block;
    font-size: 0.75rem;
    color: var(--accent-green);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  .contact-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    line-height: 1.15;
    margin-bottom: 1rem;
  }

  .contact-sub {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.8;
  }

  .contact-right {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    transition: background 0.2s;
  }

  .contact-link:last-child {
    border-bottom: none;
  }

  .contact-link:hover {
    background: var(--bg-card);
  }

  .contact-link:hover .contact-arrow {
    color: var(--accent-green);
    transform: translateX(4px);
  }

  .contact-link-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 110px;
  }

  .contact-code {
    font-size: 0.65rem;
    color: var(--accent-green);
    letter-spacing: 0.12em;
    border: 1px solid rgba(0, 212, 161, 0.3);
    padding: 0.1rem 0.4rem;
    text-transform: uppercase;
  }

  .contact-label {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .contact-value {
    flex: 1;
    font-size: 0.8rem;
    color: var(--text-primary);
    letter-spacing: 0.02em;
  }

  .contact-arrow {
    font-size: 0.85rem;
    color: var(--text-muted);
    transition: color 0.2s, transform 0.2s;
  }

  .footer-line {
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
